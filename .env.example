# CS 1.6 LAN Party Server Configuration
# Copy this file to .env and edit values before deployment

# ============================================================================
# NETWORK PORTS
# ============================================================================

# Server ports (host ports mapped to container port 27015)
# Change these if ports are already in use
TOURNAMENT_PORT=27015
PUBLIC_PORT=27016
PRACTICE_PORT=27017
GUNGAME_PORT=27018
TDM_BOTS_PORT=27019
FFA_BOTS_PORT=27020
SURF_PORT=27021
AIM_PORT=27022

# External server IP for server browser listings (optional)
# SERVER_EXTERNAL_IP="your.public.ip.address"

# ============================================================================
# SERVER NAMES
# ============================================================================

# Server hostnames displayed in server browser
TOURNAMENT_HOSTNAME="zukka CS 1.6 Tournament Server - Competitive 5v5"
PUBLIC_HOSTNAME="zukka CS 1.6 Team Deathmatch - Casual Play"
PRACTICE_HOSTNAME="zukka CS 1.6 FFA Deathmatch - Instant Respawn"
GUNGAME_HOSTNAME="zukka CS 1.6 GunGame - Weapon Progression"
TDM_BOTS_HOSTNAME="zukka CS 1.6 Team Deathmatch WITH BOTS - Casual Play"
FFA_BOTS_HOSTNAME="zukka CS 1.6 FFA Deathmatch WITH BOTS - Instant Respawn"
SURF_HOSTNAME="zukka CS 1.6 Surf Server - Movement & Skill"
AIM_HOSTNAME="zukka CS 1.6 Aim Server - Fast-Paced Aim Training"

# ============================================================================
# SERVER INFORMATION
# ============================================================================

# Server contact info displayed in server browser
SERVER_CONTACT="lan@zukkafabrik.de"
SERVER_REGION=3  # 3 = Europe

# ============================================================================
# RCON PASSWORDS (must match servers/*/server.cfg)
# ============================================================================

# Tournament server RCON password
# TOURNAMENT_RCON_PASSWORD="zukka_tournament_rcon_secure"

# Team Deathmatch server RCON password
# PUBLIC_RCON_PASSWORD="zukka_public_rcon_secure"

# FFA Deathmatch server RCON password
# PRACTICE_RCON_PASSWORD="zukka_practice_rcon_secure"

# GunGame server RCON password
# GUNGAME_RCON_PASSWORD="zukka_gungame_rcon_secure"

# TDM with BOTS server RCON password
# TDM_BOTS_RCON_PASSWORD="zukka_public_bots_rcon_secure"

# FFA with BOTS server RCON password
# FFA_BOTS_RCON_PASSWORD="zukka_ffa_bots_rcon_secure"

# Surf server RCON password
# SURF_RCON_PASSWORD="zukka_surf_rcon_secure"

# Aim server RCON password
# AIM_RCON_PASSWORD="zukka_aim_rcon_secure"

# ============================================================================
# DOCKER & SYSTEM CONFIGURATION
# ============================================================================

# GLIBC compatibility for GoldSrc on modern systems
GLIBC_TUNABLES=glibc.rtld.execstack=2

# Docker platform (set to linux/amd64 for ARM compatibility)
# DOCKER_DEFAULT_PLATFORM=linux/amd64

# Docker Compose project name (optional)
# COMPOSE_PROJECT_NAME=zukka-cs16

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Edit the .env file with your desired values
# 3. RCON passwords must match those in servers/*/server.cfg files
# 4. If ports are already in use, change the PORT variables
# 5. Run ./deploy.sh to start servers

# Server types:
# - Tournament: 5v5 competitive on empty maps
# - Public: Team Deathmatch (casual team play)
# - Practice: FFA Deathmatch with instant respawn
# - GunGame: Free-for-all weapon progression mode
# - TDM with BOTS: Team Deathmatch with AI bots
# - FFA with BOTS: Free-for-all Deathmatch with AI bots
# - Surf: Movement-based surfing gameplay
# - Aim: Fast-paced aim training maps

# Maximum players per server:
# Tournament: 12 (5v5 + 2 spectators)
# Public: 16 (Team Deathmatch)
# Practice: 16 (FFA Deathmatch)
# GunGame: 16 (GunGame)
# TDM with BOTS: 16 (Team Deathmatch with AI bots)
# FFA with BOTS: 16 (FFA Deathmatch with AI bots)
# Surf: 16 (Surf gameplay)
# Aim: 16 (Aim training)
