# zukka CS 1.6 Tournament Server Environment Configuration
# Copy this file to .env and modify the values for your deployment
# Tournament Hub: hub.zukkafabrik.de | LAN Event: lan.zukkafabrik.de
# Contact: lan@zukkafabrik.de

# ============================================================================
# DOCKER & SYSTEM CONFIGURATION
# ============================================================================

# Docker Compose project name (optional, auto-generated from directory name)
# COMPOSE_PROJECT_NAME=zukka-cs16

# GLIBC compatibility for GoldSrc on modern systems
GLIBC_TUNABLES=glibc.rtld.execstack=2

# Docker platform (set to linux/amd64 for ARM compatibility)
# DOCKER_DEFAULT_PLATFORM=linux/amd64

# ============================================================================
# NETWORK & CONNECTION SETTINGS
# ============================================================================

# External server IP address (for server listings and MOTD)
# SERVER_EXTERNAL_IP=your.public.ip.address

# Tournament server port mapping (host:container)
TOURNAMENT_PORT=27015
# PUBLIC_PORT=27016
# PRACTICE_PORT=27017

# Server hostnames (displayed in server browser)
TOURNAMENT_HOSTNAME="zukka CS 2v2 Tournament - Competitive CS 1.6"
PUBLIC_HOSTNAME="zukka CS 1.6 Public Server - Casual Fun"
PRACTICE_HOSTNAME="zukka CS 1.6 Practice Server - Training Ground"

# Server contact information (displayed in server browser)
SERVER_CONTACT=lan@zukkafabrik.de
SERVER_REGION=3  # 3 = Europe

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# RCON passwords for server administration
TOURNAMENT_RCON_PASSWORD=zukka_tournament_rcon_secure
PUBLIC_RCON_PASSWORD=zukka_public_rcon_secure
PRACTICE_RCON_PASSWORD=zukka_practice_rcon_secure

# Tournament match passwords (set via tournament hub)
# TOURNAMENT_MATCH_PASSWORD=match_specific_password_here
# TOURNAMENT_SPECTATOR_PASSWORD=spectator_password_here

# ReUnion SteamID hash salt (from Dockerfile)
REUNION_STEAMID_HASH_SALT=ThisIsMyRandomSalt123456789

# ============================================================================
# TOURNAMENT SERVER SETTINGS
# ============================================================================

# Tournament server player limits
TOURNAMENT_MAXPLAYERS=8          # 4 players + 4 spectators
TOURNAMENT_PLAYERS_PER_TEAM=2    # 2v2 format

# Tournament game settings
TOURNAMENT_ROUNDTIME=1.75        # 1 minute 45 seconds per round
TOURNAMENT_FREEZETIME=5          # 5 second freeze time
TOURNAMENT_BUYTIME=0.25          # 15 second buy time
TOURNAMENT_STARTMONEY=800        # Starting money

# Tournament rules
TOURNAMENT_FRIENDLYFIRE=1        # 1 = ON, 0 = OFF
TOURNAMENT_ALLTALK=0             # 0 = Team talk only
TOURNAMENT_AUTOTEAMBALANCE=0     # 0 = Disabled for tournament matches

# ============================================================================
# PUBLIC SERVER SETTINGS
# ============================================================================

PUBLIC_MAXPLAYERS=24
PUBLIC_ROUNDTIME=2.5
PUBLIC_FREEZETIME=6
PUBLIC_BUYTIME=0.5
PUBLIC_STARTMONEY=800
PUBLIC_FRIENDLYFIRE=0
PUBLIC_ALLTALK=1                 # 1 = All talk enabled
PUBLIC_AUTOTEAMBALANCE=1         # 1 = Enabled for casual play

# ============================================================================
# PRACTICE SERVER SETTINGS
# ============================================================================

PRACTICE_MAXPLAYERS=12
PRACTICE_ROUNDTIME=9             # Extended rounds for practice
PRACTICE_FREEZETIME=0            # No freeze time
PRACTICE_BUYTIME=60              # 60 second buy time
PRACTICE_STARTMONEY=16000        # Maximum money for practice
PRACTICE_FRIENDLYFIRE=0
PRACTICE_ALLTALK=1
PRACTICE_CHEATS=1                # 1 = Enable sv_cheats for practice commands

# ============================================================================
# ZUKKAFABRIK INTEGRATION
# ============================================================================

# Tournament hub integration
TOURNAMENT_HUB_URL=hub.zukkafabrik.de
LAN_EVENT_URL=lan.zukkafabrik.de

# Server logging level (higher = more detailed)
# 0 = Off, 1 = Basic, 2 = Detailed, 3 = Everything
TOURNAMENT_LOG_DETAIL=3
PUBLIC_LOG_DETAIL=1
PRACTICE_LOG_DETAIL=1

# VAC security (1 = Enabled, 0 = Disabled)
VAC_SECURE=1

# ============================================================================
# ADVANCED SETTINGS (Modify with caution)
# ============================================================================

# Server performance settings
SV_MAXRATE=25000
SV_MINRATE=10000
SV_MAXUPDATERATE=101
SV_MINUPDATERATE=30
SYS_TICRATE=100

# Voice settings
SV_VOICECODEC=voice_speex
SV_VOICEQUALITY=5

# Download settings
SV_ALLOWDOWNLOAD=1
SV_ALLOWUPLOAD=0

# Spectator settings
ALLOW_SPECTATORS=1
SV_SPECTALK=1                    # Spectators can talk to each other

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Edit the .env file with your specific values
# 3. Keep .env secure - it contains passwords!
# 4. Update server configs after changing .env values
# 5. Restart servers: docker compose restart

# For tournament organizers:
# - Set match-specific passwords via tournament hub
# - Use RCON for match administration
# - Monitor logs for match results

# zukka Tournament System v1.0
